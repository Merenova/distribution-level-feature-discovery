{
  "experiment_name": "gaussian_test",
  "random_seed": 42,
  "global": {
    "_comment": "Global defaults that can be overridden by stage-specific settings",
    "batch_size": 512,
    "max_seq_len": 64
  },
  "data": {
    "cloze_dir": "data/cloze_llm_improved_split_ratio_0.1",
    "split": "train",
    "raw_cloze_dir": "data/cloze_with_alea_complete"
  },
  "stage_0_preprocess": {
    "enabled": false,
    "skip_rule_based": false,
    "skip_llm": false,
    "skip_split": false,
    "llm_model": "Qwen/Qwen3-30B-A3B-Instruct-2507-FP8",
    "llm_batch_size": 16,
    "llm_gpu_memory": 0.8,
    "split_ratio": 0.1,
    "split_seed": 42
  },
  "stage_1_data_prep": {
    "mode": "cloze",
    "n_groups": 50
  },
  "model": {
    "base_model": "Qwen/Qwen3-4B",
    "transcoder": "mwhanna/qwen3-4b-transcoders",
    "dtype": "bfloat16",
    "device": "cuda"
  },
  "vllm": {
    "gpu_memory_utilization": 0.6,
    "tensor_parallel_size": 1,
    "max_model_len": 256,
    "_max_model_len_comment": "Uses global.max_seq_len if not specified",
    "trust_remote_code": true
  },
  "sampling": {
    "max_total_continuations": 1000,
    "nucleus_p": 0.9,
    "temperature": 1.0,
    "max_tokens": 30,
    "_batch_size_comment": "Uses global.batch_size if not specified",
    "batch_size": 100,
    "max_batches": 100
  },
  "embedding": {
    "model_name": "google/embeddinggemma-300m",
    "method": "contextual_continuation",
    "batch_size": 32
  },
  "attribution": {
    "max_n_logits": 151936,
    "desired_logit_prob": 0.9,
    "_batch_size_comment": "Uses global.batch_size if not specified",
    "batch_size": 256,
    "max_feature_nodes": 8192,
    "offload": "cpu",
    "_span_mode_options": "full | lcs_plus_one | post_lcs",
    "_span_mode_comment": "full: entire continuation, lcs_plus_one: up to distinguishing token, post_lcs: after distinguishing token",
    "span_mode": "post_lcs",
    "_store_all_comment": "If true, store token-level attributions so downstream stages can apply pooling mean|max|sum. If false, store compact summed attributions; downstream stages use mean-equivalent pooling by dividing by span length.",
    "store_all": true,
    "backend": "transformerlens"
  },
  "clustering": {
    "beta": 5.0,
    "gamma": 0.5,
    "K_max": 20,
    "max_iterations": 50,
    "convergence_threshold": 0.001,
    "attribution_metric": "l1",
    "_weight_mode_options": "probability | perplexity",
    "weight_mode": "perplexity",
    "_include_first_token_prob_comment": "If true, P(cont) = P(first_token) * P(cont|first_token) / sum. If false, drops P(first_token).",
    "include_first_token_prob": false,
    "_use_continuation_attribution_comment": "If true, use continuation attribution from Stage 3 (new format). If false, use Graph.pt from Stage 2 (legacy).",
    "use_continuation_attribution": true,
    "_pooling_options": "mean | max | sum",
    "_pooling_comment": "Pooling method for continuation-level attribution. mean is supported with store_all=false; sum is supported when compact summed attributions are stored; max requires store_all=true.",
    "pooling": "mean",
    "save_intermediate": false,
    "_n_prefix_workers_comment": "Number of workers for parallel prefix processing. If > 1, sweeps inside each prefix are sequential.",
    "n_prefix_workers": 12,
    "_sweeps_comment": "If sweeps dict is non-empty with beta_values and gamma_values, sweep mode is enabled. Otherwise single mode uses beta/gamma above.",
    "sweeps": {
      "beta_values": [
        1,
        5,
        10,
        30
      ],
      "gamma_values": [
        0.1,
        0.3,
        0.5,
        0.7,
        0.9
      ],
      "selection_method": "harmonic",
      "_selection_method_options": "harmonic | pareto",
      "n_workers": 64
    },
    "_sweep_example": {
      "beta_values": [
        1,
        5,
        10,
        50,
        100
      ],
      "gamma_values": [
        0.1,
        0.3,
        0.5,
        0.7,
        0.9
      ],
      "selection_method": "harmonic",
      "_selection_method_options": "harmonic | pareto",
      "n_workers": 4
    }
  },
  "stage_7c_steering": {
    "enabled": true,
    "_comment": "Uses on-the-fly steering with column-wise encoder and dynamic delta computation. Correctly handles compounding effects for all methods.",
    "_comment_single_vs_sweep": "If sweeps array is non-empty, sweep mode is enabled. Otherwise single mode uses defaults below.",
    "_steering_method_options": "multiplicative | additive | absolute | sign | scaling",
    "steering_method": "sign",
    "_h_c_selection_options": "full | positive | negative",
    "h_c_selection": "full",
    "_h_c_strategy_options": "H_c (=H_0+Delta) | Delta_H_c (=centered) | H_c_centered (=cluster-centered)",
    "h_c_strategy": "H_c_centered",
    "_feature_selection_options": "magnitude | distinct",
    "feature_selection": "distinct",
    "_hypotheses_options": "H4a (dose-response teacher-forcing) | H4a_gen (generation sampling) | H4c (specificity)",
    "hypotheses": [
      "H4a",
      "H4c"
    ],
    "epsilon_values": [
      -1,
      -0.5,
      -0.25,
      -0.1,
      -0.05,
      0.05,
      0.1,
      0.25,
      0.5,
      1
    ],
    "top_B": 10,
    "max_cluster_samples": -1,
    "max_samples_per_token": -1,
    "max_samples": -1,
    "log_details": true,
    "_generation_params_comment": "Parameters for H4a_gen (steered generation experiment)",
    "gen_num_samples_per_epsilon": 5,
    "gen_max_new_tokens": 50,
    "gen_temperature": 1.0,
    "gen_top_k": 50,
    "gen_top_p": 0.95,
    "_max_batch_size_comment": "Max batch size for forward passes. 0 or -1 = use global.batch_size. Higher=faster but more VRAM.",
    "max_batch_size": -1,
    "_cross_prefix_batching_comment": "Enable heterogeneous batching across clusters/prefixes for better GPU utilization.",
    "cross_prefix_batching": false,
    "_sweeps_comment": "Sweep mode: each sweep can override steering_method, h_c_selections, top_B, epsilon_values, h_c_strategy, feature_selection. Empty array = single mode.",
    "sweeps": [
      {
        "name": "sign",
        "steering_method": "sign",
        "h_c_selections": [
          "full",
          "positive",
          "negative"
        ],
        "top_B": [
          5,
          10
        ],
        "h_c_strategy": [
          "H_c"
        ],
        "epsilon_values": [
          -1,
          -0.5,
          -0.25,
          0,
          0.25,
          0.5,
          1
        ]
      }
    ],
    "_sweeps_example": [
      {
        "name": "multiplicative_sweep",
        "steering_method": "multiplicative",
        "h_c_selections": [
          "full",
          "positive",
          "negative"
        ],
        "top_B": [
          5,
          10
        ],
        "epsilon_values": [
          -1.0,
          -0.5,
          0.0,
          0.5,
          1.0
        ],
        "h_c_strategy": "Delta_H_c",
        "feature_selection": "magnitude"
      }
    ],
    "legacy_config": {
      "beta": 15000,
      "gamma": 0.8
    },
    "backend": "transformerlens"
  }
}
